# Zorunlu — Anthropic API anahtarı
# https://console.anthropic.com/settings/keys adresinden al
ANTHROPIC_API_KEY=sk-ant-...

# Opsiyonel — Firecrawl (premium web scraping)
# https://firecrawl.dev/app/api-keys
# Boş bırakılırsa radar sadece public RSS feed'leri kullanır
FIRECRAWL_API_KEY=

# Opsiyonel — email yayın için SMTP
# Boş bırakılırsa publisher sadece markdown dosya üretir
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
REPORT_TO_EMAIL=
# SMTP_SSL=1 ise doğrudan SSL (port 465); 0 ise STARTTLS (port 587)
SMTP_SSL=0

# Yayın eşiği — 0-10 arası; bu puanın üstündekiler rapora girer
QUALITY_THRESHOLD=6.5

# Model seçimi — Bölüm 6.5 heterojen kullanım için ayrı ayrı tanımlanır
WRITER_MODEL=claude-sonnet-4-5
EVALUATOR_MODEL=claude-haiku-4-5

# Eşzamanlı API çağrı limiti — rate limit + connection pool koruması
# Düşük tier (Tier 1) için 3-5; yüksek tier için 10-20
MAX_CONCURRENCY=5
